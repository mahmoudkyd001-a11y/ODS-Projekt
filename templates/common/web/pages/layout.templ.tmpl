package pages

templ Layout(title string, serviceName string) {
    <html>
    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>{ title } – OZG-Portal</title>
        <link rel="stylesheet" href="/css/bootstrap.min.css"/>
        <link rel="stylesheet" href="/css/bootstrap-icons.min.css"/>
        <style>
            .navbar-brand { font-weight: 600; }
            .sidebar { min-height: calc(100vh - 56px); border-right: 1px solid #dee2e6; }
            .sidebar .nav-link { color: #495057; border-radius: 6px; }
            .sidebar .nav-link:hover { background-color: #f8f9fa; color: #0d6efd; }
            .sidebar .nav-link.active { background-color: #e7f1ff; color: #0d6efd; font-weight: 500; }
            .main-content { background-color: #f8f9fa; min-height: calc(100vh - 56px); }
            footer { border-top: 1px solid #dee2e6; }
        </style>
    </head>
    <body>
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">
                    <i class="bi bi-building me-2"></i>
                    OZG-Bürgerportal
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/"><i class="bi bi-house me-1"></i>Start</a>
                        </li>
                        if serviceName != "" {
                        <li class="nav-item">
                            <a class="nav-link active" href="/{ serviceName }">
                                <i class="bi bi-file-earmark-text me-1"></i>{ title }
                            </a>
                        </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="#"><i class="bi bi-list-ul me-1"></i>Meine Anträge</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
{{- if .AddTOTP }}
                            <a class="nav-link" href="/auth/login"><i class="bi bi-person-circle me-1"></i>Anmelden</a>
{{- else }}
                            <a class="nav-link" href="#"><i class="bi bi-person-circle me-1"></i>Anmelden</a>
{{- end }}
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Inhalt -->
        <div class="container-fluid">
            <div class="row">
                <!-- Sidebar -->
                <div class="col-md-2 sidebar bg-white py-3 px-3">
                    <p class="text-muted small fw-bold mb-2">NAVIGATION</p>
                    <ul class="nav flex-column gap-1">
                        <li class="nav-item">
                            <a class="nav-link" href="/">
                                <i class="bi bi-house me-2"></i>Startseite
                            </a>
                        </li>
                        if serviceName != "" {
                        <li class="nav-item">
                            <a class="nav-link active" href="/{ serviceName }">
                                <i class="bi bi-file-earmark-text me-2"></i>{ title }
                            </a>
                        </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link" href="#">
                                <i class="bi bi-clock-history me-2"></i>Meine Anträge
                            </a>
                        </li>
                    </ul>
{{- if .AddTOTP }}
                    <hr/>
                    <p class="text-muted small fw-bold mb-2">KONTO</p>
                    <ul class="nav flex-column gap-1">
                        <li class="nav-item">
                            <a class="nav-link" href="/auth/login">
                                <i class="bi bi-person me-2"></i>Anmelden
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/auth/register">
                                <i class="bi bi-shield-lock me-2"></i>2FA / TOTP
                            </a>
                        </li>
                    </ul>
{{- end }}
                </div>

                <!-- Hauptinhalt -->
                <div class="col-md-10 main-content py-4 px-4">
                    { children... }
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer class="bg-white py-3 mt-auto">
            <div class="container-fluid px-4">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted small">OZG-Portal · Fraunhofer FOKUS · Gruppe 11 · 2026</span>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-muted small text-decoration-none">Datenschutz</a>
                        <a href="#" class="text-muted small text-decoration-none">Impressum</a>
                        <a href="#" class="text-muted small text-decoration-none">Barrierefreiheit</a>
                    </div>
                </div>
            </div>
        </footer>

        <script src="/js/bootstrap.bundle.min.js"></script>
        <script src="/js/htmx.min.js"></script>
    </body>
    </html>
}