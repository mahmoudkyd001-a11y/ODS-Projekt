package pages

{{range .Schemas.List}}
templ {{.ComponentName}}Form() {
    @Layout("{{.H1Name}}", "{{.Name}}") {
        <div class="row justify-content-center">
            <div class="col-md-9">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>{{.H1Name}}</h4>
                    </div>
                    <div class="card-body">
                        <form hx-post="/{{.Name}}" hx-target="#result" hx-swap="innerHTML">
                            {{if .HasGroups}}
                            {{range .Groups}}
                            {{if .Name}}
                            <div class="card mb-4 border-primary">
                                <div class="card-header bg-light fw-bold text-primary">
                                    {{.Name}}
                                </div>
                                <div class="card-body">
                                    {{range .Properties}}
                                    <div class="mb-3">
                                        <label for="{{.Name}}" class="form-label fw-bold">
                                            {{.UILabel}}
                                            {{if .UIRequired}}<span class="text-danger">*</span>{{end}}
                                        </label>
                                        {{if eq .UIControl "textarea"}}
                                        <textarea id="{{.Name}}" name="{{.Name}}" class="form-control" rows="4" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}></textarea>
                                        {{else if eq .UIControl "checkbox"}}
                                        <div class="form-check">
                                            <input type="checkbox" id="{{.Name}}" name="{{.Name}}" class="form-check-input" {{if .UIRequired}}required{{end}}/>
                                            <label class="form-check-label" for="{{.Name}}">{{.UILabel}}</label>
                                        </div>
                                        {{else if eq .UIControl "file"}}
                                        <input type="file" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                        {{else if eq .UIControl "select"}}
                                        <select id="{{.Name}}" name="{{.Name}}" class="form-select" {{if .UIRequired}}required{{end}}>
                                            <option value="">Bitte wählen...</option>
                                            {{range .UIOptions}}
                                            <option value="{{.}}">{{.}}</option>
                                            {{end}}
                                        </select>
                                        {{else if eq .UIControl "email"}}
                                        <input type="email" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                        {{else if eq .UIControl "password"}}
                                        <input type="password" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                        {{else if eq .UIControl "date"}}
                                        <input type="date" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                        {{else if eq .UIControl "number"}}
                                        <input type="number" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                        {{else if eq .UIControl "tel"}}
                                        <input type="tel" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                        {{else}}
                                        <input type="{{if eq .Type "integer"}}number{{else if eq .Type "boolean"}}checkbox{{else}}text{{end}}" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                        {{end}}
                                    </div>
                                    {{end}}
                                </div>
                            </div>
                            {{else}}
                            {{range .Properties}}
                            <div class="mb-3">
                                <label for="{{.Name}}" class="form-label fw-bold">
                                    {{.UILabel}}
                                    {{if .UIRequired}}<span class="text-danger">*</span>{{end}}
                                </label>
                                {{if eq .UIControl "textarea"}}
                                <textarea id="{{.Name}}" name="{{.Name}}" class="form-control" rows="4" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}></textarea>
                                {{else if eq .UIControl "checkbox"}}
                                <div class="form-check">
                                    <input type="checkbox" id="{{.Name}}" name="{{.Name}}" class="form-check-input" {{if .UIRequired}}required{{end}}/>
                                    <label class="form-check-label" for="{{.Name}}">{{.UILabel}}</label>
                                </div>
                                {{else if eq .UIControl "file"}}
                                <input type="file" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                {{else if eq .UIControl "select"}}
                                <select id="{{.Name}}" name="{{.Name}}" class="form-select" {{if .UIRequired}}required{{end}}>
                                    <option value="">Bitte wählen...</option>
                                    {{range .UIOptions}}
                                    <option value="{{.}}">{{.}}</option>
                                    {{end}}
                                </select>
                                {{else if eq .UIControl "email"}}
                                <input type="email" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                {{else if eq .UIControl "password"}}
                                <input type="password" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                {{else if eq .UIControl "date"}}
                                <input type="date" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                {{else if eq .UIControl "number"}}
                                <input type="number" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                {{else if eq .UIControl "tel"}}
                                <input type="tel" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                {{else}}
                                <input type="{{if eq .Type "integer"}}number{{else if eq .Type "boolean"}}checkbox{{else}}text{{end}}" id="{{.Name}}" name="{{.Name}}" class="form-control" placeholder="{{.UIPlaceholder}}" {{if .UIRequired}}required{{end}}/>
                                {{end}}
                            </div>
                            {{end}}
                            {{end}}
                            {{end}}
                            {{end}}
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-send me-2"></i>Absenden
                                </button>
                            </div>
                        </form>
                        <div id="result" class="mt-3"></div>
                    </div>
                </div>
            </div>
        </div>
    }
}
{{end}}