package pages

{{range .Schemas.List}}
templ {{.ComponentName}}Form() {
    <html>
    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <title>{{.H1Name}}</title>
        <link rel="stylesheet" href="/css/bootstrap.min.css"/>
    </head>
    <body>
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="card shadow">
                        <div class="card-header bg-primary text-white">
                            <h2 class="mb-0">{{.H1Name}}</h2>
                        </div>
                        <div class="card-body">
                            <form hx-post="/{{.Name}}" hx-target="#result" hx-swap="innerHTML">
                                {{range .Properties}}
                                <div class="mb-3{{if .UIGroup}} group-{{.UIGroup}}{{end}}">
                                    <label for="{{.Name}}" class="form-label fw-bold">
                                        {{.LabelName}}
                                        {{if .UIRequired}}<span class="text-danger">*</span>{{end}}
                                    </label>
                                    {{if eq .UIControl "textarea"}}
                                    <textarea id="{{.Name}}" name="{{.Name}}" class="form-control" rows="4" {{if .UIRequired}}required{{end}}></textarea>
                                    {{else if eq .UIControl "checkbox"}}
                                    <div class="form-check">
                                        <input type="checkbox" id="{{.Name}}" name="{{.Name}}" class="form-check-input" {{if .UIRequired}}required{{end}}/>
                                        <label class="form-check-label" for="{{.Name}}">{{.LabelName}}</label>
                                    </div>
                                    {{else if eq .UIControl "file"}}
                                    <input type="file" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                    {{else if eq .UIControl "select"}}
                                    <select id="{{.Name}}" name="{{.Name}}" class="form-select" {{if .UIRequired}}required{{end}}>
                                        <option value="">Bitte wählen...</option>
                                        {{range .UIOptions}}
                                        <option value="{{.}}">{{.}}</option>
                                        {{end}}
                                    </select>
                                    {{else if eq .UIControl "email"}}
                                    <input type="email" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                    {{else if eq .UIControl "password"}}
                                    <input type="password" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                    {{else if eq .UIControl "date"}}
                                    <input type="date" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                    {{else if eq .UIControl "number"}}
                                    <input type="number" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                    {{else if eq .UIControl "tel"}}
                                    <input type="tel" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                    {{else}}
                                    <input type="{{if eq .Type "integer"}}number{{else if eq .Type "boolean"}}checkbox{{else}}text{{end}}" id="{{.Name}}" name="{{.Name}}" class="form-control" {{if .UIRequired}}required{{end}}/>
                                    {{end}}
                                </div>
                                {{end}}
                                <div class="d-grid mt-4">
                                    <button type="submit" class="btn btn-primary btn-lg">Absenden</button>
                                </div>
                            </form>
                            <div id="result" class="mt-3"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script src="/js/bootstrap.bundle.min.js"></script>
        <script src="/js/htmx.min.js"></script>
    </body>
    </html>
}
{{end}}