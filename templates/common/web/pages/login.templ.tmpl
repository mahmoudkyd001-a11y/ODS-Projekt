package pages

templ LoginForm() {
    @Layout("Anmelden", "login") {
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="bi bi-box-arrow-in-right me-2"></i>Anmelden</h4>
                    </div>
                    <div class="card-body">
                        <form hx-post="/auth/login" hx-target="#result" hx-swap="innerHTML">
                            <div class="mb-3">
                                <label for="email" class="form-label fw-bold">
                                    E-Mail<span class="text-danger">*</span>
                                </label>
                                <input type="email" id="email" name="email"
                                       class="form-control"
                                       placeholder="beispiel@email.de"
                                       required/>
                            </div>
                            <div class="mb-3">
                                <label for="password" class="form-label fw-bold">
                                    Passwort<span class="text-danger">*</span>
                                </label>
                                <input type="password" id="password" name="password"
                                       class="form-control"
                                       placeholder="Passwort"
                                       required/>
                            </div>
                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="bi bi-arrow-right me-2"></i>Weiter
                                </button>
                            </div>
                        </form>
                        <div id="result" class="mt-3"></div>
                        <hr/>
                        <p class="text-center text-muted">
                            Noch kein Konto? <a href="/auth/register">Jetzt registrieren</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
}