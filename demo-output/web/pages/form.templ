package pages


templ BaumfaellungForm() {
    @Layout("Baumfaellung", "baumfaellung") {
        <div class="row justify-content-center">
            <div class="col-md-9">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Baumfaellung</h4>
                    </div>
                    <div class="card-body">
                        <form hx-post="/baumfaellung" hx-target="#result" hx-swap="innerHTML">
                            <div class="mb-4">
                                <div class="d-flex flex-wrap gap-2 mb-2" id="step-pills">
                                    
                                    <span class="badge rounded-pill bg-secondary" data-pill="0">
                                        baum
                                    </span>
                                    
                                    <span class="badge rounded-pill bg-secondary" data-pill="1">
                                        personal
                                    </span>
                                    
                                    <span class="badge rounded-pill bg-secondary" data-pill="2">
                                        Weitere Angaben
                                    </span>
                                    
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-primary" role="progressbar" id="step-progress" style="width: 0%;"></div>
                                </div>
                            </div>
                            
                            <div class="form-step" data-step="0">
                                
                                <div class="card mb-4 border-primary">
                                    <div class="card-header bg-light fw-bold text-primary">
                                        baum
                                    </div>
                                    <div class="card-body">
                                        
                                        <div class="mb-3">
                                            <label for="baumumfang" class="form-label fw-bold">
                                                Baumumfang
                                                
                                            </label>
                                            
                                            <input type="number" id="baumumfang" name="baumumfang" class="form-control" placeholder="" />
                                            
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="denkmalschutz" class="form-label fw-bold">
                                                Denkmalschutz
                                                
                                            </label>
                                            
                                            <div class="form-check">
                                                <input type="checkbox" id="denkmalschutz" name="denkmalschutz" class="form-check-input" />
                                                <label class="form-check-label" for="denkmalschutz">Denkmalschutz</label>
                                            </div>
                                            
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="eigentuemer" class="form-label fw-bold">
                                                Eigentuemer
                                                <span class="text-danger">*</span>
                                            </label>
                                            
                                            <input type="text" id="eigentuemer" name="eigentuemer" class="form-control" placeholder="" required/>
                                            
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="baumart" class="form-label fw-bold">
                                                Baumart
                                                <span class="text-danger">*</span>
                                            </label>
                                            
                                            <input type="text" id="baumart" name="baumart" class="form-control" placeholder="" required/>
                                            
                                        </div>
                                        
                                    </div>
                                </div>
                                
                            </div>
                            
                            <div class="form-step" data-step="1">
                                
                                <div class="card mb-4 border-primary">
                                    <div class="card-header bg-light fw-bold text-primary">
                                        personal
                                    </div>
                                    <div class="card-body">
                                        
                                        <div class="mb-3">
                                            <label for="adresse" class="form-label fw-bold">
                                                Adresse
                                                <span class="text-danger">*</span>
                                            </label>
                                            
                                            <input type="text" id="adresse" name="adresse" class="form-control" placeholder="" required/>
                                            
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="email" class="form-label fw-bold">
                                                Email
                                                <span class="text-danger">*</span>
                                            </label>
                                            
                                            <input type="text" id="email" name="email" class="form-control" placeholder="" required/>
                                            
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label for="nachname" class="form-label fw-bold">
                                                Nachname
                                                <span class="text-danger">*</span>
                                            </label>
                                            
                                            <input type="text" id="nachname" name="nachname" class="form-control" placeholder="" required/>
                                            
                                        </div>
                                        
                                    </div>
                                </div>
                                
                            </div>
                            
                            <div class="form-step" data-step="2">
                                
                                
                                <div class="mb-3">
                                    <label for="begruendung" class="form-label fw-bold">
                                        Begruendung
                                        <span class="text-danger">*</span>
                                    </label>
                                    
                                    <textarea id="begruendung" name="begruendung" class="form-control" rows="4" placeholder="" required></textarea>
                                    
                                </div>
                                
                                <div class="mb-3">
                                    <label for="massnahme" class="form-label fw-bold">
                                        Massnahme
                                        <span class="text-danger">*</span>
                                    </label>
                                    
                                    <select id="massnahme" name="massnahme" class="form-select" required>
                                        <option value="">Bitte wählen...</option>
                                        
                                    </select>
                                    
                                </div>
                                
                                <div class="mb-3">
                                    <label for="fotos" class="form-label fw-bold">
                                        Fotos
                                        
                                    </label>
                                    
                                    <input type="file" id="fotos" name="fotos" class="form-control" />
                                    
                                </div>
                                
                                <div class="mb-3">
                                    <label for="standort" class="form-label fw-bold">
                                        Standort
                                        <span class="text-danger">*</span>
                                    </label>
                                    
                                    <input type="text" id="standort" name="standort" class="form-control" placeholder="" required/>
                                    
                                </div>
                                
                                <div class="mb-3">
                                    <label for="baumhoehe" class="form-label fw-bold">
                                        Baumhoehe
                                        <span class="text-danger">*</span>
                                    </label>
                                    
                                    <input type="text" id="baumhoehe" name="baumhoehe" class="form-control" placeholder="" required/>
                                    
                                </div>
                                
                                <div class="mb-3">
                                    <label for="dokument" class="form-label fw-bold">
                                        Dokument
                                        
                                    </label>
                                    
                                    <input type="file" id="dokument" name="dokument" class="form-control" />
                                    
                                </div>
                                
                                <div class="mb-3">
                                    <label for="vorname" class="form-label fw-bold">
                                        Vorname
                                        
                                    </label>
                                    
                                    <input type="text" id="vorname" name="vorname" class="form-control" placeholder="" />
                                    
                                </div>
                                
                                
                            </div>
                            
                            <div class="d-flex justify-content-between mt-4">
                                <button type="button" class="btn btn-outline-secondary" id="step-back">
                                    <i class="bi bi-arrow-left me-1"></i>Zurück
                                </button>
                                <button type="button" class="btn btn-primary" id="step-next">
                                    Weiter<i class="bi bi-arrow-right ms-1"></i>
                                </button>
                                <button type="submit" class="btn btn-primary btn-lg" id="step-submit" style="display:none;">
                                    <i class="bi bi-send me-2"></i>Absenden
                                </button>
                            </div>
                        </form>
                        <div id="result" class="mt-3"></div>
                       <script>
                                                   (function () {
                                                       var steps = document.querySelectorAll(".form-step");
                                                       var pills = document.querySelectorAll("[data-pill]");
                                                       var progress = document.getElementById("step-progress");
                                                       var backBtn = document.getElementById("step-back");
                                                       var nextBtn = document.getElementById("step-next");
                                                       var submitBtn = document.getElementById("step-submit");
                                                       var total = steps.length;
                                                       var current = 0;

                                                       function show(i) {
                                                           current = i;
                                                           for (var s = 0; s < steps.length; s++) {
                                                               steps[s].style.display = (s === i) ? "" : "none";
                                                           }
                                                           for (var p = 0; p < pills.length; p++) {
                                                               pills[p].className = "badge rounded-pill " + (p <= i ? "bg-primary" : "bg-secondary");
                                                           }
                                                           var pct = Math.round(((i + 1) / total) * 100);
                                                           progress.style.width = pct + "%";
                                                           backBtn.style.display = (i === 0) ? "none" : "";
                                                           nextBtn.style.display = (i === total - 1) ? "none" : "";
                                                           submitBtn.style.display = (i === total - 1) ? "" : "none";
                                                       }

                                                       function validateStep(i) {
                                                           var fields = steps[i].querySelectorAll("input, select, textarea");
                                                           var firstInvalid = null;
                                                           for (var f = 0; f < fields.length; f++) {
                                                               if (fields[f].checkValidity()) {
                                                                   fields[f].classList.remove("is-invalid");
                                                               } else {
                                                                   fields[f].classList.add("is-invalid");
                                                                   if (firstInvalid === null) firstInvalid = fields[f];
                                                               }
                                                           }
                                                           if (firstInvalid !== null) {
                                                               firstInvalid.reportValidity();
                                                               return false;
                                                           }
                                                           return true;
                                                       }

                                                       if (total > 0) {
                                                           nextBtn.addEventListener("click", function () {
                                                               if (!validateStep(current)) return;
                                                               if (current < total - 1) show(current + 1);
                                                           });
                                                           backBtn.addEventListener("click", function () {
                                                               if (current > 0) show(current - 1);
                                                           });
                                                           show(0);
                                                       }
                                                   })();
                       </script>
                    </div>
                </div>
            </div>
        </div>
    }
}
